---
servers:
  hosts:
    my-host:
      ansible_host: 1.2.3.4              # IP or hostname of your target machine
      rancher_hostname: rancher.example.com  # FQDN used for the Rancher URL
      ansible_user: root
      ansible_ssh_private_key_file: ~/.ssh/id_rsa
      ansible_ssh_common_args: >-
        -o StrictHostKeyChecking=no
        -o UserKnownHostsFile=/dev/null
